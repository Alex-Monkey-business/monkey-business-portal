---
---

<div class="phone">
  <div class="phone-screen">
    <div class="phone-body scr-season" data-phone-loop="season" data-step="0">
      <div class="ss-title">Season settlement</div>
      <div class="ss-sub">Spring 2026</div>

      <div class="ss-kpis">
        <div class="ss-kpi">
          <div class="ss-kpi-v" data-kpi-target="12">0</div>
          <div class="ss-kpi-k">Matches</div>
        </div>
        <div class="ss-kpi">
          <div class="ss-kpi-v" data-kpi-target="8400" data-kpi-suffix=" kr">0 kr</div>
          <div class="ss-kpi-k">Total</div>
        </div>
      </div>

      <div class="ss-card">
        <div class="ss-card-head">Expenses per coach</div>
        <div class="ss-table-head">
          <span>COACH</span>
          <span>MATCHES</span>
          <span>PAID</span>
        </div>
        <div class="ss-rows">
          <div class="ss-row is-me" style="--i:0">
            <div class="ss-name"><strong>Alex</strong></div>
            <div class="ss-k" data-kpi-target="5">0</div>
            <div class="ss-v" data-kpi-target="2400" data-kpi-suffix=" kr">0 kr</div>
          </div>
          <div class="ss-row" style="--i:1">
            <div class="ss-name">Iver</div>
            <div class="ss-k" data-kpi-target="3">0</div>
            <div class="ss-v" data-kpi-target="1600" data-kpi-suffix=" kr">0 kr</div>
          </div>
          <div class="ss-row" style="--i:2">
            <div class="ss-name">Jacob</div>
            <div class="ss-k" data-kpi-target="2">0</div>
            <div class="ss-v" data-kpi-target="1200" data-kpi-suffix=" kr">0 kr</div>
          </div>
          <div class="ss-row" style="--i:3">
            <div class="ss-name">Simon</div>
            <div class="ss-k" data-kpi-target="1">0</div>
            <div class="ss-v" data-kpi-target="800" data-kpi-suffix=" kr">0 kr</div>
          </div>
          <div class="ss-row" style="--i:4">
            <div class="ss-name">Trond</div>
            <div class="ss-k" data-kpi-target="1">0</div>
            <div class="ss-v" data-kpi-target="2400" data-kpi-suffix=" kr">0 kr</div>
          </div>
        </div>
      </div>

      <button class="ss-export">
        <span class="dl">↓</span>
        Export to Excel
      </button>
    </div>
    <div class="phone-home"></div>
  </div>
</div>
