---
---

<div class="phone">
  <div class="phone-screen">
    <div class="phone-body scr-dash" data-phone-loop="dashboard" data-step="0">
      <div class="scr-head">
        <div class="scr-title">Spring 2026</div>
      </div>

      <div class="scr-filter-group">
        <div class="flabel">Where</div>
        <div class="chips" data-chip-group="where">
          <button class="chip is-active" data-val="all">All <span class="num">27</span></button>
          <button class="chip" data-val="home">Home <span class="num">15</span></button>
          <button class="chip" data-val="away">Away <span class="num">12</span></button>
        </div>
      </div>

      <div class="scr-filter-group">
        <div class="flabel">Squad</div>
        <div class="chips" data-chip-group="team">
          <button class="chip is-active" data-val="all">All <span class="num">27</span></button>
          <button class="chip" data-val="g"><i class="tdot g"></i>Green <span class="num">9</span></button>
          <button class="chip" data-val="r"><i class="tdot r"></i>Red <span class="num">9</span></button>
          <button class="chip" data-val="w"><i class="tdot w"></i>White <span class="num">9</span></button>
        </div>
      </div>

      <div class="scr-section-head">
        Upcoming matches <span class="mini-pill">26</span>
      </div>

      <div class="scr-matches">
        <article class="match-card" data-team="g" data-where="away">
          <div class="mc-head">
            <span class="mini-chip"><i class="tdot g"></i>Green</span>
            <span class="mini-chip sub">Away</span>
            <span class="mc-time">18:00</span>
          </div>
          <div class="mc-vs">Halsen G.<span class="dash">vs</span>Sandefjord</div>
        </article>

        <article class="match-card" data-team="g" data-where="home">
          <div class="mc-head">
            <span class="mini-chip"><i class="tdot g"></i>Green</span>
            <span class="mini-chip sub">Home</span>
            <span class="mc-time">17:30</span>
          </div>
          <div class="mc-vs">Halsen G.<span class="dash">vs</span>Tønsberg</div>
        </article>

        <article class="match-card" data-team="r" data-where="home">
          <div class="mc-head">
            <span class="mini-chip"><i class="tdot r"></i>Red</span>
            <span class="mini-chip sub">Home</span>
            <span class="mc-time">18:00</span>
          </div>
          <div class="mc-vs">Halsen R.<span class="dash">vs</span>Borre FK</div>
        </article>

        <article class="match-card" data-team="w" data-where="home">
          <div class="mc-head">
            <span class="mini-chip"><i class="tdot w"></i>White</span>
            <span class="mini-chip sub">Home</span>
            <span class="mc-time">19:15</span>
          </div>
          <div class="mc-vs">Halsen W.<span class="dash">vs</span>Stag</div>
        </article>
      </div>
    </div>
    <div class="phone-home"></div>
  </div>
</div>
