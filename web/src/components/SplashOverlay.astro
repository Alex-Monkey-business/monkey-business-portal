---
// First-load splash. Shown once per tab session (sessionStorage flag
// `mb-splash-seen`). A gating class on <html> set in Layout.astro hides
// it on return visits before any paint, so there is no flash.
---

<div class="mb-splash" id="mb-splash" role="presentation">
  <div class="mb-splash__stage" aria-hidden="true">
    <svg class="mb-splash__monkey" viewBox="0 0 300 240" fill="none">
      <g class="mb-splash__strokes" stroke="currentColor" stroke-width="12" stroke-linecap="round" stroke-linejoin="round">
        <path class="mb-splash__draw mb-splash__draw--ear-l"   pathLength="1" d="M104 150 C84 132 72 109 72 84 C72 52 94 30 124 30"/>
        <path class="mb-splash__draw mb-splash__draw--ear-r"   pathLength="1" d="M196 150 C216 132 228 109 228 84 C228 52 206 30 176 30"/>
        <path class="mb-splash__draw mb-splash__draw--inner-l" pathLength="1" d="M78 86 C62 86 50 97 50 112 C50 127 62 138 78 138"/>
        <path class="mb-splash__draw mb-splash__draw--inner-r" pathLength="1" d="M222 86 C238 86 250 97 250 112 C250 127 238 138 222 138"/>
        <path class="mb-splash__draw mb-splash__draw--chin"    pathLength="1" d="M110 150 C114 179 127 202 150 214 C173 202 186 179 190 150"/>
        <path class="mb-splash__draw mb-splash__draw--tuft"    pathLength="1" d="M112 40 C122 18 148 12 164 20 C171 11 183 10 194 14 C186 26 177 37 166 42"/>
      </g>
      <path class="mb-splash__draw mb-splash__draw--mouth" pathLength="1"
            stroke="currentColor" stroke-width="10" stroke-linejoin="round"
            d="M100 96 C100 80 114 68 132 68 H168 C186 68 200 80 200 96 C200 112 186 124 168 124 H132 C114 124 100 112 100 96 Z"/>
      <path class="mb-splash__pop mb-splash__pop--eye-l" fill="currentColor"
            d="M112 99 C122 88 135 87 144 99 C135 107 122 107 112 99 Z"/>
      <path class="mb-splash__pop mb-splash__pop--eye-r" fill="currentColor"
            d="M156 99 C165 87 178 88 188 99 C178 107 165 107 156 99 Z"/>
      <path class="mb-splash__draw mb-splash__draw--smile" pathLength="1"
            stroke="currentColor" stroke-width="7" stroke-linecap="round"
            d="M144 128 C148 133 152 133 156 128"/>
      <path class="mb-splash__pop mb-splash__pop--nose" fill="currentColor"
            d="M150 126 L144 136 H156 Z"/>
    </svg>

    <svg class="mb-splash__mark" viewBox="0 0 392 222" fill="none">
      <g stroke="currentColor" stroke-width="18" stroke-linecap="round" stroke-linejoin="round">
        <path d="M60 184 V70 Q60 38 90 38"/>
        <path d="M60 114 H85 C100 114 109 110 114 99"/>
        <path d="M124 184 V38 L172 116 L220 38 V184"/>
        <path d="M252 184 V38"/>
        <path d="M252 38 H285 C315 38 328 55 328 78 C328 102 314 114 284 114 H252"/>
        <path d="M252 114 H286 C318 114 332 130 332 150 C332 173 318 184 286 184 H252"/>
      </g>
    </svg>
  </div>
</div>

<style>
  .mb-splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg);
    color: var(--fg1);
    animation: mb-out 460ms cubic-bezier(0.4, 0, 1, 1) 1700ms forwards;
    will-change: opacity;
  }

  .mb-splash.is-dismissed {
    animation: mb-out 260ms cubic-bezier(0.4, 0, 1, 1) forwards;
  }

  :global(html.splash-seen) .mb-splash {
    display: none;
  }

  .mb-splash__stage {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(20px, 3.5vw, 36px);
    width: min(46vw, 280px);
    transform-origin: 50% 60%;
    animation: mb-settle 720ms cubic-bezier(0.22, 1, 0.36, 1) 980ms backwards;
  }

  .mb-splash__monkey {
    width: 100%;
    height: auto;
    color: var(--fg1);
    overflow: visible;
  }

  .mb-splash__mark {
    width: 38%;
    height: auto;
    color: var(--fg3);
    opacity: 0;
    transform: translateY(6px);
    animation: mb-mark-in 720ms cubic-bezier(0.16, 1, 0.3, 1) 1180ms forwards;
  }

  /* Stroke draw — paths render via stroke-dashoffset 1 → 0 */
  .mb-splash__draw {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: mb-draw 760ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  /* Draw choreography — slight asymmetry between mirrored pairs */
  .mb-splash__draw--ear-l   { animation-delay:   0ms; }
  .mb-splash__draw--ear-r   { animation-delay:  80ms; }
  .mb-splash__draw--inner-l { animation-delay: 220ms; animation-duration: 620ms; }
  .mb-splash__draw--inner-r { animation-delay: 280ms; animation-duration: 620ms; }
  .mb-splash__draw--chin    { animation-delay: 380ms; animation-duration: 720ms; }
  .mb-splash__draw--tuft    { animation-delay: 460ms; animation-duration: 560ms; }
  .mb-splash__draw--mouth   { animation-delay: 540ms; animation-duration: 720ms; }
  .mb-splash__draw--smile   { animation-delay: 920ms; animation-duration: 360ms; }

  /* Filled features pop in once their parent stroke has drawn */
  .mb-splash__pop {
    transform-box: fill-box;
    transform-origin: center;
    transform: scale(0);
    opacity: 0;
    animation: mb-pop 320ms cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  .mb-splash__pop--eye-l { animation-delay: 760ms; }
  .mb-splash__pop--eye-r { animation-delay: 820ms; }
  .mb-splash__pop--nose  { animation-delay: 980ms; }

  @keyframes mb-draw {
    to { stroke-dashoffset: 0; }
  }
  @keyframes mb-pop {
    0%   { transform: scale(0);    opacity: 0; }
    60%  { transform: scale(1.12); opacity: 1; }
    100% { transform: scale(1);    opacity: 1; }
  }
  @keyframes mb-settle {
    0%   { transform: scale(0.985); }
    100% { transform: scale(1); }
  }
  @keyframes mb-mark-in {
    0%   { opacity: 0; transform: translateY(6px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  @keyframes mb-out {
    to { opacity: 0; visibility: hidden; pointer-events: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mb-splash { animation: mb-out 220ms linear 700ms forwards; }
    .mb-splash__stage { animation: none; }
    .mb-splash__draw { stroke-dashoffset: 0; animation: none; }
    .mb-splash__pop  { transform: scale(1); opacity: 1; animation: none; }
    .mb-splash__mark { opacity: 1; transform: none; animation: none; }
  }
</style>

<script is:inline>
  (() => {
    const splash = document.getElementById('mb-splash');
    if (!splash) return;
    if (document.documentElement.classList.contains('splash-seen')) {
      splash.remove();
      return;
    }

    try { sessionStorage.setItem('mb-splash-seen', '1'); } catch (_) {}
    document.documentElement.classList.add('splash-playing');

    const cleanup = () => {
      document.documentElement.classList.remove('splash-playing');
      document.documentElement.classList.add('splash-seen');
      splash.remove();
    };

    const dismiss = () => {
      if (splash.classList.contains('is-dismissed')) return;
      splash.classList.add('is-dismissed');
    };

    splash.addEventListener('animationend', (e) => {
      if (e.animationName === 'mb-out') cleanup();
    });
    splash.addEventListener('click', dismiss);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') dismiss();
    }, { once: true });

    setTimeout(cleanup, 4000);
  })();
</script>
