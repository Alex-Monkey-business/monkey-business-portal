---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
---

<Layout>
  <section class="hero">
    <h1 class="hero-title">
      <span class="line"><span>Alex</span></span>
      <span class="line"><span><em>Monkey business</em>.</span></span>
    </h1>
    <p class="hero-sub">Small experiments, side projects and ideas</p>
    <div class="illo" aria-hidden="true"></div>
  </section>

  <section class="projects-wrap" id="projects">
    <span class="projects-label">
      Projects · {String(projects.length).padStart(2, '0')}
    </span>
    <ul class="projects">
      {
        projects.map((p, i) => {
          const href = p.url ?? `/projects/${p.slug}`;
          const external = Boolean(p.url);
          return (
            <li style={`--i:${i}`}>
              <a
                href={href}
                class={external ? 'is-external' : undefined}
                target={external ? '_blank' : undefined}
                rel={external ? 'noopener noreferrer' : undefined}
              >
                <span class="title">
                  {p.title}
                  {p.titleEm && (
                    <>
                      {' '}
                      <em>{p.titleEm}</em>
                    </>
                  )}
                  {p.status === 'wip' && <span class="tag">wip</span>}
                  {external && <span class="ext" aria-hidden="true">↗</span>}
                </span>
                {p.subtitle && <span class="subtitle">{p.subtitle}</span>}
                <span class="year">{p.year}</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </section>
</Layout>

<script>
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-in');
          obs.unobserve(e.target);
        }
      });
    },
    { threshold: 0.2 }
  );
  document
    .querySelectorAll('ul.projects li')
    .forEach((li) => obs.observe(li));
</script>
