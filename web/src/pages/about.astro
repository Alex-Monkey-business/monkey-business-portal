---
import Layout from '../layouts/Layout.astro';
import '../styles/about.css';
---

<Layout title="About — Alex Monkey Business">
  <section class="about">
    <div class="about-grid">
      <figure class="about-portrait">
        <img src="/assets/about/alex.png" alt="Alexander Samnøy" />
      </figure>

      <div class="about-copy">
        <span class="about-eyebrow" style="--i:0">About</span>
        <h1 class="about-title">
          <span class="line" style="--i:1">Builder<em>.</em></span>
        </h1>
        <p class="about-body">
          <span class="line" style="--i:2">Product guy by profession. Side hustles by <em>nature</em>.</span>
          <span class="line" style="--i:3">Inspired by Elon Musk’s ambition and Candide Thovex’s flow.</span>
        </p>
      </div>
    </div>
  </section>
</Layout>
