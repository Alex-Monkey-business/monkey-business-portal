---
import '../styles/global.css';
import '../styles/landing.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SplashOverlay from '../components/SplashOverlay.astro';

interface Props {
  title?: string;
  description?: string;
  accent?: string;
}

const {
  title = 'Alex Monkey Business',
  description = "A portal to the things I'm tinkering with.",
  accent,
} = Astro.props;

const htmlStyle = accent
  ? `--accent: ${accent}; --coral-500: ${accent};`
  : undefined;
---

<!doctype html>
<html lang="en" style={htmlStyle}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/brand/icons/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/brand/icons/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/brand/icons/favicon-16.png" />
    <link rel="apple-touch-icon" href="/brand/icons/apple-touch-icon.png" />
    <link rel="mask-icon" href="/brand/icons/mask-icon.svg" color="#C85E87" />
    <meta name="theme-color" content="#C85E87" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/brand/social-og-image.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/brand/social-og-image.png" />
    <script is:inline>
      try {
        if (localStorage.getItem('mb-theme') === 'dark') {
          document.documentElement.classList.add('dark');
        }
      } catch (_) {}
      try {
        if (sessionStorage.getItem('mb-splash-seen') === '1') {
          document.documentElement.classList.add('splash-seen');
        }
      } catch (_) {}
    </script>
  </head>
  <body>
    <SplashOverlay />
    <Nav />
    <main id="top">
      <slot />
      <Footer />
    </main>
  </body>
</html>
